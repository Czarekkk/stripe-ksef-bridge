# =========================================================================
# stripe-ksef-bridge — konfiguracja
# Uruchamiaj przez:  op run --env-file=.env -- npm run dev
# Wartości op://... są podstawiane z 1Password w runtime (nie lądują na dysku).
# Skopiuj ten plik do .env i uzupełnij.
# =========================================================================

# --- Serwer ---
PORT=3000

# --- Stripe ---
# Restricted key. Dla invoice.paid musi mieć tez 'customer read' (rak_customer_read).
STRIPE_API_KEY=op://vault/stripe-agent/credential
# Webhook signing secret (whsec_...). Z `stripe listen` (lokalnie) albo z panelu Stripe.
STRIPE_WEBHOOK_SECRET=op://vault/stripe-webhook/credential
# App signing secret (absec_...). Dashboard -> Apps -> <app> -> ... -> Signing secret.
# Włącza edycję ustawień z panelu (weryfikacja podpisu fetchStripeSignature). Bez niego: tylko `npm run config`.
STRIPE_APP_SECRET=op://vault/ksef-app-secret/credential

# --- KSeF ---
# test  -> api-test.ksef.mf.gov.pl  (fikcyjny NIP, self-signed cert OK)
# demo  -> api-demo.ksef.mf.gov.pl  (realny NIP, realny cert)
# prod  -> api.ksef.mf.gov.pl
KSEF_ENV=test
KSEF_NIP=0000000000

# Tryb autoryzacji: 'certificate' (certyfikat KSeF, XAdES) lub 'token' (token KSeF).
KSEF_AUTH_MODE=token

# Tryb 'certificate': plik PKCS#12 z certyfikatem KSeF (cert + klucz prywatny).
KSEF_CERT_PATH=./secrets/ksef-cert.p12
KSEF_CERT_PASSWORD=op://vault/ksef-cert/password

# Tryb 'token': token KSeF (string) wygenerowany w Aplikacji Podatnika KSeF.
KSEF_TOKEN=op://vault/ksef-token/credential

# --- Sprzedawca (dane na fakturze) ---
SELLER_NIP=0000000000
SELLER_NAME=ReceptionOS sp. z o.o.
SELLER_ADDRESS_COUNTRY=PL
SELLER_ADDRESS_LINE1=ul. Przykładowa 1
SELLER_ADDRESS_POSTAL=00-001
SELLER_ADDRESS_CITY=Warszawa
SELLER_REGON=                                    # opcjonalny — trafia do Stopki FA(3)

# --- Numeracja faktur ---
# Format: tokeny {n} {n3} {MM} {YYYY} {YY}. Domyślnie jak w Saldeo: {n}/{MM}/{YYYY} (np. 9/06/2026).
# SEED = ostatni numer z Saldeo w roku cutoveru; SEED_YEAR = ten rok (kolejne lata startują od 1).
INVOICE_NUMBER_FORMAT={n}/{MM}/{YYYY}
INVOICE_NUMBER_SEED=0
INVOICE_NUMBER_SEED_YEAR=2026

# --- Baza (ledger) ---
# Lokalnie: plik w ./data. Na Railway: plik na WOLUMENIE zamontowanym w /data:
#   DATABASE_URL=file:/data/ksef-bridge.db
# (Turso byłoby potrzebne tylko na hostingu bez trwałego dysku, np. Cloudflare Containers.)
DATABASE_URL=file:./data/ksef-bridge.db
# DATABASE_AUTH_TOKEN=   # tylko dla libsql:// (Turso) — na Railway niepotrzebne

# --- Panel (Stripe App) ---
# Opcjonalny bearer chroniący zapis /config wołany przez panel/skrypt.
BRIDGE_API_TOKEN=op://vault/ksef-bridge-api/credential

# --- Powiadomienia e-mail (MailerSend) ---
# Alert po wystawieniu / błędzie / fakturze do ręcznego wystawienia. Best-effort (brak konfiguracji = brak maili).
# Wysyłka z domeny zweryfikowanej w MailerSend; token mlsn.…
NOTIFY_EMAIL=ops@example.com
NOTIFY_FROM=ksef@example.com
NOTIFY_FROM_NAME=KSeF Bridge
MAILERSEND_TOKEN=op://vault/mailersend/credential
